{
  "name": "skm-workshop-management",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Taller Mecánico de Motos",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "npm run deploy:migrate && node backend/src/server.js",
    "build": "npm install --prefix backend && npm install --prefix frontend && npm run build --prefix frontend",
    "postinstall": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "deploy:migrate": "npx prisma migrate deploy --schema=backend/prisma/schema.prisma",
    "db:seed": "node backend/prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.12.1"
  },
  "devDependencies": {
    "prisma": "^5.12.1"
  }
}
